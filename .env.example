# Copie este arquivo para .env se quiser sobrescrever as configuracoes locais.

# Banco demo com dados ficticios para portfolio:
DATABASE_URL=sqlite:///data/demo.db

# Troque este valor caso publique a aplicacao em algum ambiente online.
SECRET_KEY=troque-esta-chave-antes-de-publicar

# Duracao da sessao em segundos. Padrao: 8 horas.
SESSION_MAX_AGE_SECONDS=28800
